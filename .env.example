# Copy to .env for local dev. In TrueNAS SCALE Custom App, set these as env vars directly.

# TrueNAS websocket JSON-RPC endpoint. Verify port on your box:
# some 25.10.x builds answer on wss://<ip>:8444/websocket, others on wss://<ip>/api/current
TRUENAS_URL=wss://192.168.1.36:8444/websocket

# TrueNAS API key (Settings > API Keys). NEVER commit a real key.
TRUENAS_API_KEY=REPLACE_ME

# FleetDeck admin UI password (single admin account).
ADMIN_PASSWORD=REPLACE_ME

# Secret used to sign session cookies. NEVER commit a real value.
COOKIE_SECRET=REPLACE_ME

# Port FleetDeck's HTTP server listens on (UI + API + /boot/*).
HTTP_PORT=8080

# Bind address. Keep this on the LAN only — /boot/* is unauthenticated (firmware can't auth).
HTTP_BIND=0.0.0.0

# When "1", every TrueNAS mutation is logged but not executed. Use for first bring-up.
DRY_RUN=1

# Path to the SQLite state file (mount a host-path volume over its directory).
DB_PATH=/data/fleetdeck.sqlite3

# Base IQN for iSCSI targets.
IQN_PREFIX=iqn.2005-10.org.freenas.ctl

# Zvol path for the golden (sysprepped) image, snapshots named @gold-vN under it.
GOLDEN_ZVOL=Main_pool/iscsi/win-golden

# Root dataset path where per-client clone zvols live.
CLIENT_ZVOL_ROOT=Main_pool/iscsi
